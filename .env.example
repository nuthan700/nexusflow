# Copy this file to .env and fill in real values before running.

# Django
SECRET_KEY=change-this-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=

# Leave POSTGRES_DB unset to use local sqlite instead (fine for quick local dev).
POSTGRES_DB=chatapp
POSTGRES_USER=chatapp
POSTGRES_PASSWORD=chatapp
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Leave REDIS_URL unset to use the in-memory channel layer (single process only).
REDIS_URL=redis://redis:6379
